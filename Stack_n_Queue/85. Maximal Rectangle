class Solution {
public:
    int maxRect(vector<int>& nums){
        int n=nums.size();
        vector<int> nse(n,n),pse(n,-1);
        stack<int> st;
        for(int i=n-1;i>=0;i--){
            while(!st.empty() && nums[st.top()]>=nums[i]){
                st.pop();
            }
            if(!st.empty()) nse[i]=st.top();
            st.push(i);
        }
        while(!st.empty()) st.pop();
        for(int i=0;i<n;i++){
            while(!st.empty() && nums[st.top()]>=nums[i]){
                st.pop();
            }
            if(!st.empty()) pse[i]=st.top();
            st.push(i);
        }

        int maxarea=0;
        for(int i=0;i<n;i++){
            maxarea=max(maxarea,nums[i]*(nse[i]-pse[i]-1));
        }
        return maxarea;

    }
    int maximalRectangle(vector<vector<char>>& mat) {
        int m=mat.size();
        int n=mat[0].size();
        vector<vector<int>> grid(m,vector<int> (n,0));
        for(int j=0;j<n;j++){
            for(int i=0;i<m;i++){
                if(mat[i][j]=='0') continue;
                else{
                    if(i==0) grid[i][j]=1;
                    else grid[i][j]=grid[i-1][j]+1;
                }
            }
        }

        int maxarea=0;
        for(int i=0;i<m;i++){
            maxarea=max(maxarea,maxRect(grid[i]));
        }
        return maxarea;


    }
};
