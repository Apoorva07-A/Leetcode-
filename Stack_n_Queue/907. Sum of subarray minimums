class Solution {
public:
    int sumSubarrayMins(vector<int>& nums) {
        int mod=1e9+7;
        int n=nums.size();
        vector<int> nse(n,n);
        vector<int> pse(n,-1);
        stack<int> st;
        for(int i=n-1;i>=0;i--){
            while(!st.empty() && nums[st.top()]>=nums[i]){
                st.pop();
            }
            if(st.empty()) nse[i]=n;
            else nse[i]=st.top();
            st.push(i);
        }
        for(int i=0;i<n;i++){
            cout<<nse[i]<<" ";
        }
        cout<<endl;
        
        while(!st.empty()) st.pop();
        for(int i=0;i<n;i++){
            while(!st.empty() && nums[st.top()]>nums[i]){
                st.pop();
            }
            if(st.empty()) pse[i]=-1;
            else pse[i]=st.top();
            st.push(i);
        }

        for(int i=0;i<n;i++){
            cout<<pse[i]<<" ";
        }
        long long total=0;
        

for (int i = 0; i < n; i++) {
    long long left = i - pse[i];
    long long right = nse[i] - i;

    long long contribution =
        (1LL * nums[i] * left % mod) * right % mod;

    total = (total + contribution) % mod;
}
        return (int)total;

    }
};
