class Solution {
public:
    string removeKdigits(string num, int k) {
        int n=num.size();
        if(n==k) return "0";
        stack<char> st;
        for(int i=0;i<n;i++){
            if(st.empty()) st.push(num[i]);
            else if(st.top()>num[i] && k>0){
                
                while(!st.empty() && st.top()>num[i] && k>0){
                    st.pop();
                    k--;
                }
                st.push(num[i]);
                
                
            }else{
                st.push(num[i]);
            }
        }
        while(k){
            st.pop();
            k--;
        }
        num="";
        while(!st.empty()){
            num+=st.top();
            st.pop();   
    
        }
        reverse(num.begin(),num.end());
        int i=0;
        while(num[i]=='0') i++;
        n=num.size();
        if(i==n) return "0";
        return num.substr(i,n-i);

        
    }
};
