class Solution {
public:
    int lps(int i,int j,string s){
        if(i==j) return 1;
        else if(i>j) return 0;
        else{
            int nottake=max(lps(i+1,j,s),lps(i,j-1,s));
            if(s[i]==s[j]){
                return max(lps(i+1,j-1,s)+2,nottake);
            }
            return nottake;
        }
    }
    int longestPalindromeSubseq(string s) {

        vector<vector<int>> dp(s.size(),vector<int> (s.size(),0));
        for(int i=s.size()-1;i>=0;i--){
            for(int j=0;j<s.size();j++){
                if(i==j){
                    dp[i][j]=1;
                }else if(i>j){
                    dp[i][j]=0;
                }else{
                    int nottake=max(dp[i+1][j],dp[i][j-1]);
                    if(s[i]==s[j]){
                    dp[i][j]=max(dp[i+1][j-1]+2,nottake);
                    }
                    else dp[i][j]=nottake;
                }
            }
        }
        return dp[0][s.size()-1];
    }
};
