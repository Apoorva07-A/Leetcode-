/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
public:
    unordered_map<TreeNode*,pair<TreeNode*,int>> parent;
    int maxtime=0;
    TreeNode* target;
    void func(TreeNode* root,int start){
        if(root==NULL) return;
        if(root->val==start) target=root;
        if(root->left!=NULL){
            parent[root->left]={root,0};
        }
        if(root->right!=NULL) parent[root->right]={root,0};
        func(root->left,start);
        func(root->right,start);
    }
    void traverse(TreeNode* curr,int k){
        if(curr==NULL || parent[curr].second==1) maxtime=max(maxtime,k-1);
        else{
            parent[curr].second=1;
            traverse(parent[curr].first,k+1);
            traverse(curr->left,k+1);
            traverse(curr->right,k+1);
            parent[curr].second=0;
        }

    }
    int amountOfTime(TreeNode* root, int start) {
        func(root,start);
        parent[root]={NULL,0};
        traverse(target,0);
        return maxtime;
    }
};
