*/

class Solution {
public:
    map<int,Node*> mpp;
    void func(int row,Node* root){
        if(root==NULL) return;
        if(mpp.find(row)==mpp.end()) mpp[row]=root;
        else{
            mpp[row]->next=root;
            mpp[row]=root;
        }
        func(row+1,root->left);
        func(row+1,root->right);
    }
    Node* connect(Node* root) {
        func(0,root);
        return root;
        
    }
};
