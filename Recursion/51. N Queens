class Solution {
public:
vector<vector<string>> ans;

vector<int> curr;
    bool isvalid(int row,int col){
        for(int i=0;i<row;i++){
            if(curr[i]==col || abs(col-curr[i])==abs(row-i)) return false;
        }
        return true;
    }
    void func(int row,int n){
        if(row>=n){
            vector<string> res;
            for(int i=0;i<n;i++){
                string a(n,'.');
                a[curr[i]]='Q';
                res.push_back(a);
            }
            ans.push_back(res);
            return;

        }
        else{
            for(int i=0;i<n;i++){
                if(isvalid(row,i)){
                    curr.push_back(i);
                    func(row+1,n);
                    curr.pop_back();
                }
            }
        }
    }
    vector<vector<string>> solveNQueens(int n) {
        func(0,n);
        return ans;
    }
};
