class Solution {
public:
    int func(int ind,int t,vector<int> & nums,vector<vector<int>>& dp){
        
        if(t==nums[ind]) return dp[ind][t]=1;
        else if(t<0) return 0;
        else if(dp[ind][t]!=-1) return  dp[ind][t];
        else{
            t-=nums[ind];
            int sum=0;
            for(int i=0;i<nums.size();i++){
              
                sum+=func(i,t,nums,dp);
            }
            t+=nums[ind];
            return dp[ind][t]=sum;
        }
    }
    int combinationSum4(vector<int>& nums, int t) {
        int sum=0;
        vector<vector<int>> dp(nums.size(),vector<int> (t+1,-1));
        for(int i=0;i<nums.size();i++){
            sum+=func(i,t,nums,dp);
        }
        return sum;
    }
};
