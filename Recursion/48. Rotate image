class Solution {
public:
    void rotate(vector<vector<int>>& matrix) {
        int n=matrix.size();
        vector<vector<int>> vis(n,vector<int> (n,0));
        for(int i=0;i<n;i++){
            for(int j=0;j<n;j++){
                if(vis[i][j]==0){
                    int x=i;
                    int y=j;
                    while(vis[x][y]==0){
                        vis[x][y]=1;
                        swap(matrix[x][y],matrix[y][n-1-x]);
                        vis[y][n-1-x]=1;
                    }

                }
            }
        }
    }
};
