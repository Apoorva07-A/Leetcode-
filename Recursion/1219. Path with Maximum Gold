class Solution {
public:
    int maxval=0;
    vector<vector<int>> vis;
    vector<vector<int>> dir={{1,0},{-1,0},{0,1},{0,-1}};
    void func(int i,int j, int val,vector<vector<int>>& grid){
        vis[i][j]=1;
        int m=grid.size();
        int n=grid[0].size();
        val+=grid[i][j];
        int proceed=0;
        for(int k=0;k<4;k++){
            int x=i+dir[k][0];
            int y=j+dir[k][1];
            if(x<m && x>=0 && y<n && y>=0){
                if(!vis[x][y] && grid[x][y]>0){
                    proceed=1;
                    func(x,y,val,grid);
                }
            }
        }
        if(!proceed){
            maxval=max(maxval,val);
        }
        vis[i][j]=0;
        val-=grid[i][j];

    }
    int getMaximumGold(vector<vector<int>>& grid) {
        int m=grid.size();
        int val=0;
        int n=grid[0].size();
        vis.resize(m,vector<int>(n,0));
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                func(i,j,val,grid);
            }
        }
        return maxval;
    }
};
