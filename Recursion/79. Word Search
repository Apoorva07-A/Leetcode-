class Solution {
public:
    vector<vector<int>> vis;
    string word;
    bool res=false;
    vector<vector<int>> dir={{1,0},{-1,0},{0,1},{0,-1}};
    void func(int i,int j,int ind,vector<vector<char>>& board,int len){
        if(ind==word.size()-1 && len==word.size()){
            res=true;
            return ;
        }else if(ind>=word.size()) return;
        else{
            for(int k=0;k<4;k++){
                int x=i+dir[k][0];
                int y=j+dir[k][1];
                if(x<vis.size() && x>=0 && y<vis[0].size() && y>=0 ){
                    if(vis[x][y]==0 && board[x][y]==word[ind+1]){
                        vis[x][y]=1;
                        func(x,y,ind+1,board,len+1);
                        vis[x][y]=0;
                    }
                }
            }
        }
    }
    bool exist(vector<vector<char>>& board, string word1) {
        word= word1;
        int len=0;
        int m=board.size();
        int n=board[0].size();
        vis.resize(m,vector<int>(n,0));
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                if(board[i][j]==word[0]){
                    vis[i][j]=1;
                    func(i,j,0,board,len+1);
                    vis[i][j]=0;
                }
            }
        }
        return res;
    }
};
