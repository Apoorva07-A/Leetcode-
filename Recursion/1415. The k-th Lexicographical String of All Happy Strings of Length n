class Solution {
public:
    string s="";
    string s2="abc";
    void func(int& n,int& k,int ind,string& sub){
        if(s!="") return;
        if(n<0 || k<0) return ;
        sub.push_back(s2[ind]);
        n--;
        if(n==0){
            k--;
            if(k==0){
                s=sub;
            }
        }else{
            for(int i=0;i<3;i++){
                if(i==ind) continue;
                func(n,k,i,sub);
            }
        }
        sub.pop_back();
        n++;
        return;
    }
    string getHappyString(int n2, int k2) {
        int n=n2;
        string sub="";
        int k=k2;
        int i=0;
        for(i=0;i<3;i++){
            func(n,k,i,sub);
        }
        
        return s;
    }
};
