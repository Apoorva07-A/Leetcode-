class Solution {
public:  
    int func(int ind,vector<int>& vis){
        if(ind==vis.size()-1){
            for(int i=0;i<vis.size();i++){
                if(!vis[i]){
                    if((i+1)%(ind+1)==0 || (ind+1)%(i+1)==0){

                        return 1;
                    }else return 0;
                }
            }
        }
        else{
            int sum=0;
            for(int i=0;i<vis.size();i++){
                if(!vis[i]){
                    if((i+1)%(ind+1)==0 || (ind+1)%(i+1)==0){
                        vis[i]=1;
                        sum+=func(ind+1,vis);
                        vis[i]=0;
                    }
                }
            }
            return sum;
        }
        return 0;
    }
    int countArrangement(int n) {
        vector<int> vis(n,0);
        return func(0,vis);
        

    }
};
