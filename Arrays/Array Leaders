

class Solution {
  public:
    vector<int> leaders(vector<int>& arr) {
        // code here
        vector<int> ans;
        int tillmax=arr[arr.size()-1];
        for(int i=arr.size()-1;i>=0;i--){
            tillmax=max(tillmax,arr[i]);
            if(arr[i]==tillmax) ans.push_back(arr[i]);
        }
        reverse(ans.begin(),ans.end());
        return ans;
    }
};
