class Solution {
public:
    void dfs(int curr,vector<vector<int>>& adj,vector<bool>& visited){
        visited[curr]=true;
        for(int i=0;i<adj.size();i++){
            if(adj[curr][i] && !visited[i]){
                dfs(i,adj,visited);
            }
        }
    }
    int findCircleNum(vector<vector<int>>& adj) {
        vector<bool> visited(adj.size(),false);
        int i=0;
        int count=0;
        while(i<visited.size()){
            if(visited[i]) i++;
            else{
                count++;
                dfs(i,adj,visited);
            }
        }
        return count;
    }
};
