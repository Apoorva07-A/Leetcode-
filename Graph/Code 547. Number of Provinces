class Solution {
public:
    int findCircleNum(vector<vector<int>>& adj) {
        queue<int> q;
        q.push(0);
        int n=adj.size();
        int province=0;
        vector<int> vis(n,0);
        vis[0]=1;
        while(!q.empty()){
            int n1=q.size();
            while(n1){
                int curr=q.front();
                n1--;
                q.pop();
                for(int i=0;i<n;i++){
                    if(adj[curr][i] && !vis[i]){
                        vis[i]=1;
                        q.push(i);
                    }
                }
            }
            if(q.empty()){
                province++;
                for(int i=0;i<n;i++){
                    if(vis[i]==0){ 
                        q.push(i);
                        break;
                    }
                }
            }
        }
        return province;
    }
};
