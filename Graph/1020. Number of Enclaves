class Solution {
public:
    vector<vector<int>> dir={{-1,0},{1,0},{0,-1},{0,1}};
    void dfs(int i,int j,vector<vector<int>>& board,vector<vector<bool>> &vis){
        int m=board.size();
        int n=board[0].size();
        vis[i][j]=true;
        for(int k=0;k<4;k++){
            int row=i+dir[k][0];
            int col=j+dir[k][1];
            if(row>=0 && row<m && col>=0 && col<n && !vis[row][col] && board[i][j]==1){
                dfs(row,col,board,vis);
            }
        }
    }
    int numEnclaves(vector<vector<int>>& board) {
        int m=board.size();
        int n=board[0].size();
        vector<vector<bool>> vis(m,vector<bool> (n,false));
        
        for(int i=0;i<m;i++){
            if(board[i][0]==1){
                dfs(i,0,board,vis);
            }
            if(board[i][n-1]==1){
                dfs(i,n-1,board,vis);
            }
        }
        for(int j=0;j<n;j++){
            if(board[0][j]==1){
                dfs(0,j,board,vis);
            }
            if(board[m-1][j]==1){
                dfs(m-1,j,board,vis);
            }
        }
        int count=0;
        for(int i=1;i<m-1;i++){
            for(int j=1;j<n-1;j++){
                if(!vis[i][j] && board[i][j]==1){
                    count++;
                }
            }
        }
        return count;
    }
};
