class Solution {
public:
    int numIslands(vector<vector<char>>& grid) {
        int m=grid.size();
        int n=grid[0].size();
        int island=0;
        vector<vector<bool>> vis(m,vector<bool>(n,false));
        vector<vector<int>> dir={{-1,0},{1,0},{0,1},{0,-1}};
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                if(grid[i][j]=='1' && !vis[i][j]){
                    island++;
                    queue<vector<int>> q;
                    q.push({i,j});
                    vis[i][j]=true;
                    while(!q.empty()){
                        vector<int> curr=q.front();
                        q.pop();
                        for(int i=0;i<4;i++){
                            int row=curr[0]+dir[i][0];
                            int col=curr[1]+dir[i][1];
                            if(row<m && row>=0 && col<n && col>=0 && !vis[row][col] && grid[row][col]=='1'){
                                vis[row][col]=true;
                                q.push({row,col});
                            }
                        }
                    }
                }
            }
        }
        return island;
    }
};
