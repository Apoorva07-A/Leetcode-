class Solution {
  public:
    vector<int> bellmanFord(int n, vector<vector<int>>& edges, int src) {
        // Code here
        vector<int> dist(n,1e8);
        dist[src]=0;
        for(int i=0;i<n;i++){
            for(int j=0;j<edges.size();j++){
                int u=edges[j][0];
                int v=edges[j][1];
                int wt=edges[j][2];
                if(dist[u]==1e8) continue;
                if(dist[u]+wt<dist[v]){
                    if(i==n-1) return {-1};
                    dist[v]=dist[u]+wt;
                }
            }
        }
        return dist;
    }
};
