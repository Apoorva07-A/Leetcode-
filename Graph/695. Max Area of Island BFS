class Solution {
public:
    int maxAreaOfIsland(vector<vector<int>>& grid) {
        int m=grid.size();
        int n=grid[0].size();

        vector<vector<bool>> vis(m,vector<bool> (n,false));
        vector<vector<int>> dir={{1,0},{-1,0},{0,1},{0,-1}};
        int maxarea=0;
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                if(grid[i][j]==1 && !vis[i][j]){
                    int area=0;
                    queue<vector<int>> q;
                    q.push({i,j});
                    vis[i][j]=true;
                    while(!q.empty()){
                        vector<int> curr=q.front();
                        q.pop();
                        area++;
                        for(int k=0;k<4;k++){
                            int row=curr[0]+dir[k][0];
                            int col=curr[1]+dir[k][1];
                            if(row>=0 && row<m && col>=0 && col<n && grid[row][col]==1 && !vis[row][col]){
                                vis[row][col]=true;
                                q.push({row,col});
                            }
                        }
                    }
                    maxarea=max(maxarea,area);
                }
                
            }
        }
        return maxarea;
    }
};
