class Solution {
public:

    int countCompleteComponents(int n, vector<vector<int>>& edges) {
        int totalconnected=0;
        vector<vector<int>> adj(n,vector<int> (n,0));
        for(int i=0;i<edges.size();i++){
            adj[edges[i][0]][edges[i][1]]=1;
            adj[edges[i][1]][edges[i][0]]=1;
        }
        vector<bool> vis(n,false);
        queue<int> q;
        for(int i=0;i<n;i++){
            vector<int> conn;
            if(!vis[i]){
                q.push(i);
                vis[i]=true;
                while(!q.empty()){
                    int curr=q.front();
                    conn.push_back(curr);
                    q.pop();
                    for(int j=0;j<n;j++){
                        if(adj[curr][j] && !vis[j]){
                            vis[j]=true;
                            q.push(j);
                        }
                    }
                }
                bool isconnected=true;
                for(int k=0;k<conn.size();k++){
                    for(int l=k+1;l<conn.size();l++){
                        if(adj[conn[k]][conn[l]]==0){
                            isconnected=false;
                            break;
                        }
                    }
                }
                if(isconnected) totalconnected++;
            }
        }
        return totalconnected;
    }
};
