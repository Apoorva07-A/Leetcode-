class Solution {
public:
    vector<vector<int>> dir={{0,-1},{0,1},{1,0},{-1,0}};
    int maxarea=0;
    int dfs(int row,int col,vector<vector<int>>& grid,vector<vector<bool>> & vis){
        int m=grid.size();
        int n=grid[0].size();
        vis[row][col]=true;
        int area=1;
        for(int i=0;i<4;i++){
            int r=row+dir[i][0];
            int c=col+dir[i][1];
            if(r<m && r>=0 && c<n && c>=0 && grid[r][c] && !vis[r][c] ){
                area+=dfs(r,c,grid,vis);
            }
        }
        return area;
    }
    int maxAreaOfIsland(vector<vector<int>>& grid) {
        int m=grid.size();
        int n=grid[0].size();
        vector<vector<bool>>  vis(m,vector<bool> (n,0));
        for(int i=0;i<m;i++){
            for(int j=0;j<n;j++){
                if(grid[i][j] && !vis[i][j]){
                    maxarea=max(maxarea,dfs(i,j,grid,vis));
                }
            }
        }
        return maxarea;
    }
};
