class Solution {
public:
    vector<int> arrayRankTransform(vector<int>& arr) {
        if(arr.size()==0) return {};
        vector<int> ans(arr.size(),0);
        priority_queue<pair<int,int>,vector<pair<int,int>>, greater<pair<int,int>>> minh;
        int rank=1;
        for(int i=0;i<arr.size();i++){
            minh.push({arr[i],i});
        }
        int last=minh.top().first;
        ans[minh.top().second]=rank;
        minh.pop();
        while(!minh.empty()){
            if(minh.top().first==last){
                ans[minh.top().second]=rank;
                minh.pop();
            }else{
                rank++;
                last=minh.top().first;
                ans[minh.top().second]=rank;
                minh.pop();
            }
        }
        return ans;

    }
};
