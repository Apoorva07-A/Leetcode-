class Solution {
  public:
    void nearlySorted(vector<int>& arr, int k) {
        // code here
         priority_queue<int,vector<int>,greater<int>> minh;
    for(int i=0;i<arr.size();i++){
        minh.push(arr[i]);
        if(minh.size()>k+1){
            arr[i-k-1]=minh.top();
            minh.pop();
        }
    }
    for(int i=arr.size()-k-1;i<arr.size();i++){
        arr[i]=minh.top();
        minh.pop();
    }
    }
};
